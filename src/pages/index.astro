---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';

const allArticles = await getCollection('articles', ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

const articles = allArticles.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const authors = await getCollection('authors');
const authorMap = new Map(authors.map((a) => [a.id, a.data.name]));
---

<BaseLayout
  title="Agents 特区"
  description="一线实践者的AI agent管理经验，从个人探索到组织级实践。"
>
  <!-- Hero Section -->
  <section class="mb-16 pt-8">
    <h1 class="font-serif text-4xl sm:text-5xl font-semibold tracking-tight text-[var(--color-text-primary)] leading-tight">
      一起探索怎么把软件工程<br class="hidden sm:block" />
      和 AI 结合，<br class="hidden sm:block" />
      让我们最终失业。
    </h1>
    <p class="mt-6 text-lg text-[var(--color-text-secondary)] leading-relaxed max-w-2xl">
      AI agent已经不是实验品了。团队在用agent写代码、做测试、跑部署、处理运维。
      这里汇集一线实践者的经验。不谈概念，谈落地。
    </p>
  </section>

  <!-- Playbook Section -->
  <section class="mb-12">
    <a href="https://agents-zone.github.io/harness-engineering-playbook/"
       target="_blank"
       rel="noopener noreferrer"
       class="block p-6 rounded-lg border border-[var(--color-surface-border)] border-l-4 border-l-[var(--color-accent)] bg-[var(--color-surface-elevated)]/60 hover:bg-[var(--color-surface-elevated)] transition-colors group">
      <div class="flex items-center gap-2 mb-3">
        <span class="text-xs font-medium uppercase tracking-widest text-[var(--color-accent)]">社区出品</span>
        <span class="text-xs text-[var(--color-text-muted)]">·</span>
        <span class="text-xs text-[var(--color-text-muted)]">持续更新中</span>
      </div>
      <h2 class="font-serif text-xl sm:text-2xl font-semibold text-[var(--color-text-primary)] group-hover:text-[var(--color-accent)] transition-colors">
        Harness Engineering Playbook
      </h2>
      <p class="mt-2 text-[var(--color-text-secondary)] leading-relaxed">
        实战手册：如何在团队中用 AI agent 稳定交付生产级代码。从单个 agent 的闭环工程，到多 agent 并行扩展，再到人机协同的组织设计——三个阶段，一线实践验证的方法论。
      </p>
      <span class="inline-flex items-center gap-1 mt-4 text-sm font-medium text-[var(--color-accent)]">
        在线阅读 →
      </span>
    </a>
  </section>

  <!-- Divider -->
  <div class="border-t border-[var(--color-surface-border)] mb-12"></div>

  <!-- Articles Section -->
  <section>
    <div class="flex items-baseline justify-between mb-8">
      <h2 class="font-serif text-2xl font-semibold text-[var(--color-text-primary)]">
        最新文章
      </h2>
      <a href="/articles" class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">
        查看全部 →
      </a>
    </div>

    <div class="space-y-0">
      {articles.map((article) => (
        <ArticleCard
          article={article}
          authorName={authorMap.get(article.data.author.id) ?? 'Unknown'}
        />
      ))}
    </div>
  </section>
</BaseLayout>
