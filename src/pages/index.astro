---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getLang, useTranslations, localePath } from '../i18n/utils';

const lang = getLang(Astro.currentLocale);
const t = useTranslations(lang);

const allArticles = await getCollection('articles', ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

const articles = allArticles
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 5);

const authors = await getCollection('authors');
const authorMap = new Map(authors.map((a) => [a.id, a.data.name]));

const sections = [
  { title: t('home.section.articles'), desc: t('home.section.articles.desc'), href: localePath(lang, '/articles') },
  { title: t('home.section.discussions'), desc: t('home.section.discussions.desc'), href: localePath(lang, '/discussions') },
  { title: t('home.section.events'), desc: t('home.section.events.desc'), href: localePath(lang, '/events') },
  { title: t('home.section.authors'), desc: t('home.section.authors.desc'), href: localePath(lang, '/authors') },
];
---

<BaseLayout
  title={t('site.name')}
  description={t('site.description')}
>
  <!-- Hero Section -->
  <section class="mb-16 pt-8">
    <h1 class="font-serif text-4xl sm:text-5xl font-semibold tracking-tight text-[var(--color-text-primary)] leading-tight">
      {t('home.hero.title')}
    </h1>
    <p class="mt-6 text-lg text-[var(--color-text-secondary)] leading-relaxed max-w-2xl">
      {t('home.hero.p1')}
    </p>
  </section>

  <!-- Divider -->
  <div class="border-t border-[var(--color-surface-border)] mb-12"></div>

  <!-- What's Here Section -->
  <section class="mb-16">
    <div class="grid gap-6 sm:grid-cols-2">
      {sections.map(({ title, desc, href }) => (
        <a href={href} class="group block rounded-lg border border-[var(--color-surface-border)] p-6 hover:border-[var(--color-accent)]/40 transition-colors">
          <h3 class="font-serif text-lg font-semibold text-[var(--color-text-primary)] group-hover:text-[var(--color-accent)] transition-colors">
            {title}
          </h3>
          <p class="mt-2 text-sm text-[var(--color-text-secondary)] leading-relaxed">
            {desc}
          </p>
        </a>
      ))}
    </div>
  </section>

  <!-- Divider -->
  <div class="border-t border-[var(--color-surface-border)] mb-12"></div>

  <!-- Latest Articles -->
  <section class="mb-16">
    <div class="flex items-baseline justify-between mb-8">
      <h2 class="font-serif text-2xl font-semibold text-[var(--color-text-primary)]">
        {t('home.latest')}
      </h2>
      <a href={localePath(lang, '/articles')} class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">
        {t('home.view.all')}
      </a>
    </div>
    <div class="space-y-0">
      {articles.map((article) => (
        <ArticleCard
          article={article}
          authorName={authorMap.get(article.data.author.id) ?? 'Unknown'}
        />
      ))}
    </div>
  </section>

  <!-- Divider -->
  <div class="border-t border-[var(--color-surface-border)] mb-12"></div>

  <!-- Join Community -->
  <section class="mb-8">
    <div class="flex flex-col items-center sm:flex-row sm:items-start gap-8">
      <div class="flex-1">
        <h2 class="font-serif text-2xl font-semibold text-[var(--color-text-primary)]">
          {t('home.join.title')}
        </h2>
        <p class="mt-3 text-[var(--color-text-secondary)] leading-relaxed">
          {t('home.join.desc')}
        </p>
      </div>
      <div class="shrink-0">
        <img
          src="/images/articles/dont-learn-ai-use-it/permanent_chatroom_qr.jpg"
          alt="WeChat QR Code"
          class="w-48 h-48 rounded-lg border border-[var(--color-surface-border)]"
        />
      </div>
    </div>
  </section>
</BaseLayout>
