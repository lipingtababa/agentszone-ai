---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getLang, useTranslations, localePath } from '../i18n/utils';

const lang = getLang(Astro.currentLocale);
const t = useTranslations(lang);

const allArticles = await getCollection('articles', ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});
const articles = allArticles
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 5);

const allAuthors = await getCollection('authors');
const authorMap = new Map(allAuthors.map((a) => [a.id, a.data.name]));

// Featured authors (those with avatars, sorted by appearance)
const featuredAuthors = allAuthors
  .filter((a) => a.data.avatar)
  .slice(0, 5);

const allEvents = await getCollection('events');
const sortedEvents = allEvents.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
// Latest event
const latestEvent = sortedEvents[0];
// Latest event with a poster for visual display
const latestEventWithPoster = sortedEvents.find((e) => e.data.poster);

// Stats
const articleCount = allArticles.filter((a) => !a.data.draft).length;
const authorCount = allAuthors.length;
const eventCount = allEvents.length;
