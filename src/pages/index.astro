---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getLang, useTranslations, localePath } from '../i18n/utils';

const lang = getLang(Astro.currentLocale);
const t = useTranslations(lang);

const allArticles = await getCollection('articles', ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

const articles = allArticles
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 5);

const authors = await getCollection('authors');
const authorMap = new Map(authors.map((a) => [a.id, a.data.name]));

const sections = [
  { title: t('home.section.articles'), desc: t('home.section.articles.desc'), href: localePath(lang, '/articles') },
  { title: t('home.section.discussions'), desc: t('home.section.discussions.desc'), href: localePath(lang, '/discussions') },
  { title: t('home.section.events'), desc: t('home.section.events.desc'), href: localePath(lang, '/events') },
  { title: t('home.section.authors'), desc: t('home.section.authors.desc'), href: localePath(lang, '/authors') },
];
---

<BaseLayout
  title={t('site.name')}
  description={t('site.description')}
>
  <!-- Hero Section -->
  <section class="mb-16 pt-8">
    <h1 class="font-serif text-4xl sm:text-5xl font-semibold tracking-tight text-[var(--color-text-primary)] leading-tight">
      {t('home.hero.title')}
    </h1>
    <p class="mt-6 text-lg text-[var(--color-text-secondary)] leading-relaxed max-w-2xl">
      {t('home.hero.p1')}
    </p>
    <p class="mt-4 text-lg text-[var(--color-text-secondary)] leading-relaxed max-w-2xl">
      {t('home.hero.p2')}
    </p>
    <p class="mt-4 text-lg text-[var(--color-text-secondary)] leading-relaxed max-w-2xl">
      {t('home.hero.p3')}
    </p>
  </section>

  <!-- Playbook Section -->
  <section class="mb-12">
    <a href="https://agents-zone.github.io/harness-engineering-playbook/"
       target="_blank"
       rel="noopener noreferrer"
       class="block p-6 rounded-lg border border-[var(--color-surface-border)] border-l-4 border-l-[var(--color-accent)] bg-[var(--color-surface-elevated)]/60 hover:bg-[var(--color-surface-elevated)] transition-colors group">
      <div class="flex items-center gap-2 mb-3">
        <span class="text-xs font-medium uppercase tracking-widest text-[var(--color-accent)]">社区出品</span>
        <span class="text-xs text-[var(--color-text-muted)]">·</span>
        <span class="text-xs text-[var(--color-text-muted)]">持续更新中</span>
      </div>
      <h2 class="font-serif text-xl sm:text-2xl font-semibold text-[var(--color-text-primary)] group-hover:text-[var(--color-accent)] transition-colors">
        Harness Engineering Playbook
      </h2>
      <p class="mt-2 text-[var(--color-text-secondary)] leading-relaxed">
        实战手册：如何在团队中用 AI agent 稳定交付生产级代码。从单个 agent 的闭环工程，到多 agent 并行扩展，再到人机协同的组织设计——三个阶段，一线实践验证的方法论。
      </p>
      <span class="inline-flex items-center gap-1 mt-4 text-sm font-medium text-[var(--color-accent)]">
        在线阅读 →
      </span>
    </a>
  </section>

  <!-- Divider -->
  <div class="border-t border-[var(--color-surface-border)] mb-12"></div>

  <!-- What's Here Section -->
  <section class="mb-16">
    <div class="grid gap-6 sm:grid-cols-2">
      {sections.map(({ title, desc, href }) => (
        <a href={href} class="group block rounded-lg border border-[var(--color-surface-border)] p-6 hover:border-[var(--color-accent)]/40 transition-colors">
          <h3 class="font-serif text-lg font-semibold text-[var(--color-text-primary)] group-hover:text-[var(--color-accent)] transition-colors">
            {title}
          </h3>
          <p class="mt-2 text-sm text-[var(--color-text-secondary)] leading-relaxed">
            {desc}
          </p>
        </a>
      ))}
    </div>
  </section>

  <!-- Divider -->
  <div class="border-t border-[var(--color-surface-border)] mb-12"></div>

  <!-- Latest Articles -->
  <section class="mb-16">
    <div class="flex items-baseline justify-between mb-8">
      <h2 class="font-serif text-2xl font-semibold text-[var(--color-text-primary)]">
        {t('home.latest')}
      </h2>
      <a href={localePath(lang, '/articles')} class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">
        {t('home.view.all')}
      </a>
    </div>
    <div class="space-y-0">
      {articles.map((article) => (
        <ArticleCard
          article={article}
          authorName={authorMap.get(article.data.author.id) ?? 'Unknown'}
        />
      ))}
    </div>
  </section>

  <!-- Divider -->
  <div class="border-t border-[var(--color-surface-border)] mb-12"></div>

  <!-- Testimonial -->
  <section class="mb-16">
    <h2 class="font-serif text-2xl font-semibold text-[var(--color-text-primary)] mb-8">
      {t('home.testimonial.title')}
    </h2>
    <blockquote class="border-l-3 border-[var(--color-accent)] pl-6">
      <p class="text-[var(--color-text-secondary)] leading-relaxed">
        {t('home.testimonial.chenhao.q1')}
      </p>
      <p class="mt-4 text-[var(--color-text-secondary)] leading-relaxed">
        {t('home.testimonial.chenhao.q2')}
      </p>
      <footer class="mt-4 text-sm text-[var(--color-text-muted)]">
        — {t('home.testimonial.chenhao.name')}
      </footer>
    </blockquote>
  </section>

  <!-- Divider -->
  <div class="border-t border-[var(--color-surface-border)] mb-12"></div>

  <!-- Join Community -->
  <section class="mb-8">
    <div class="flex flex-col items-center sm:flex-row sm:items-start gap-8">
      <div class="flex-1">
        <h2 class="font-serif text-2xl font-semibold text-[var(--color-text-primary)]">
          {t('home.join.title')}
        </h2>
        <p class="mt-3 text-[var(--color-text-secondary)] leading-relaxed">
          {t('home.join.desc')}
        </p>
      </div>
      <div class="shrink-0">
        <img
          src="/images/articles/dont-learn-ai-use-it/permanent_chatroom_qr.jpg"
          alt="WeChat QR Code"
          class="w-48 h-48 rounded-lg border border-[var(--color-surface-border)]"
        />
      </div>
    </div>
  </section>
</BaseLayout>
