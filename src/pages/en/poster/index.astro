---
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import PosterGenerator from '../../../components/poster/PosterGenerator';
import '../../../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Poster Generator - AgentsZone" description="Generate posters for AgentsZone community sessions" />
  </head>
  <body class="min-h-screen bg-[var(--color-surface)] text-[var(--color-text-primary)]">
    <Header />
    <main class="mx-auto w-full max-w-7xl px-6 py-12">
      <PosterGenerator client:idle />
    </main>
    <Footer />
  </body>
</html>
