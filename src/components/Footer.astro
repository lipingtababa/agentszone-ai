---
import { getLang, useTranslations, localePath } from '../i18n/utils';

const lang = getLang(Astro.currentLocale);
const t = useTranslations(lang);
const year = new Date().getFullYear();
const siteName = lang === 'en' ? 'AgentsZone' : 'Agents 特区';
---

<footer class="border-t border-[var(--color-surface-border)] bg-[var(--color-surface)]">
  <div class="mx-auto max-w-4xl px-6 py-12">
    <div class="flex flex-col gap-8 sm:flex-row sm:justify-between">
      <div class="max-w-xs">
        <a href="/" class="font-serif text-lg font-semibold text-[var(--color-text-primary)]">
          Agents{lang !== 'en' && ' '}<span class="text-gradient">{lang === 'en' ? 'Zone' : '特区'}</span>
        </a>
        <p class="mt-2 text-sm text-[var(--color-text-muted)] leading-relaxed">
          {t('footer.desc')}
        </p>
      </div>
      <div class="flex gap-8 text-sm">
        <div class="flex flex-col gap-2">
          <a href={localePath(lang, '/articles')} class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">{t('nav.articles')}</a>
          <a href={localePath(lang, '/authors')} class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">{t('nav.authors')}</a>
          <a href={localePath(lang, '/discussions')} class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">{t('nav.discussions')}</a>
          <a href={localePath(lang, '/events')} class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">{t('nav.events')}</a>

        </div>
        <div class="flex flex-col gap-2">
          <a href="/rss.xml" class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">RSS</a>
          <a
            href="https://github.com/lipingtababa/agentszone-ai"
            class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors"
            target="_blank"
            rel="noopener noreferrer"
          >
            {t('footer.contribute')} <span class="inline-block translate-y-[-1px] text-[10px] opacity-50">&#8599;</span>
          </a>
        </div>
      </div>
    </div>
    <div class="mt-8 pt-6 border-t border-[var(--color-surface-border)]">
      <p class="text-xs text-[var(--color-text-muted)]">
        &copy; {year} {siteName}
      </p>
    </div>
  </div>
</footer>
